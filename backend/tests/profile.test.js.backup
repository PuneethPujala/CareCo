process.env.NODE_ENV = 'test';
const request = require('supertest');
const app = require('../src/server');

// Mock Mongoose models
jest.mock('../src/models/Profile');
jest.mock('../src/models/Organization');

// Mock services
jest.mock('../src/services/auditService');

const Profile = require('../src/models/Profile');
const Organization = require('../src/models/Organization');
const { logEvent, autoLogAccess } = require('../src/services/auditService');

const { mockProfile, mockOrganization } = require('./helpers/mockModels');
const { fakeAuthenticate } = require('./helpers/mockAuth');

describe('Profile Routes', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  describe('GET /api/profile/me', () => {
    it('should return own profile', async () => {
      const profile = mockProfile({ 
        _id: 'profile123',
        email: 'test@example.com',
        role: 'care_manager',
        organizationId: 'org123'
      });
      
      const populatedProfile = {
        ...profile,
        organizationId: { _id: 'org123', name: 'Test Org', city: 'Hyderabad' }
      };
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(populatedProfile)
      });

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(profile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/me');

      expect(response.status).toBe(200);
      expect(response.body.email).toBe('test@example.com');
      expect(autoLogAccess).toHaveBeenCalledWith('profile', 'read');
    });

    it('should return 401 for unauthenticated user', async () => {
      const response = await request(app)
        .get('/api/profile/me');

      expect(response.status).toBe(401);
    });
  });

  describe('GET /api/profile/organization/:orgId', () => {
    beforeEach(() => {
      Profile.find = jest.fn();
      Profile.countDocuments = jest.fn();
    });

    it('should allow org_admin to see own org profiles', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const profiles = [
        mockProfile({ _id: 'profile1', role: 'care_manager', organizationId: 'org123' }),
        mockProfile({ _id: 'profile2', role: 'caller', organizationId: 'org123' }),
      ];
      
      Profile.find = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(profiles)
      });
      Profile.countDocuments = jest.fn().mockResolvedValue(2);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/organization/org123')
        .query({ page: 1, limit: 20 });

      expect(response.status).toBe(200);
      expect(response.body.profiles).toHaveLength(2);
      expect(autoLogAccess).toHaveBeenCalledWith('profile', 'read');
    });

    it('should return 403 for cross-org access', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org456' // Different org
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/organization/org123');

      expect(response.status).toBe(403);
      expect(response.body.error).toContain('Cannot access profiles from a different organization');
    });

    it('should allow super_admin to access any org', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      const profiles = [mockProfile({ organizationId: 'org123' })];
      
      Profile.find = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(profiles)
      });
      Profile.countDocuments = jest.fn().mockResolvedValue(1);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/organization/org123');

      expect(response.status).toBe(200);
      expect(response.body.profiles).toHaveLength(1);
    });

    it('should filter by role', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const careManagers = [mockProfile({ role: 'care_manager', organizationId: 'org123' })];
      
      Profile.find = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(careManagers)
      });
      Profile.countDocuments = jest.fn().mockResolvedValue(1);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/organization/org123')
        .query({ roleFilter: 'care_manager' });

      expect(response.status).toBe(200);
      expect(response.body.profiles).toHaveLength(1);
      expect(Profile.find).toHaveBeenCalledWith(
        expect.objectContaining({ role: 'care_manager', organizationId: 'org123' })
      );
    });

    it('should return 400 for invalid role filter', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/organization/org123')
        .query({ roleFilter: 'invalid_role' });

      expect(response.status).toBe(400);
      expect(response.body.error).toContain('Invalid role filter');
    });
  });

  describe('GET /api/profile/:id', () => {
    beforeEach(() => {
      Profile.findById = jest.fn();
    });

    it('should allow super_admin to read any profile', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      const targetProfile = mockProfile({ 
        _id: 'target123',
        organizationId: 'different-org'
      });
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(targetProfile)
      });

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
        authorizeResource: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/target123');

      expect(response.status).toBe(200);
      expect(response.body._id).toBe('target123');
    });

    it('should allow org_admin to read profiles in own org', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const targetProfile = mockProfile({ 
        _id: 'target123',
        organizationId: 'org123'
      });
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(targetProfile)
      });

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
        authorizeResource: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/target123');

      expect(response.status).toBe(200);
      expect(response.body._id).toBe('target123');
    });

    it('should return 404 for missing profile', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(null)
      });

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
        authorizeResource: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/profile/nonexistent');

      expect(response.status).toBe(404);
      expect(response.body.error).toContain('Profile not found');
    });
  });

  describe('PUT /api/profile/:id', () => {
    beforeEach(() => {
      Profile.findById = jest.fn();
      Profile.findByIdAndUpdate = jest.fn();
    });

    it('should update profile successfully', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const targetProfile = mockProfile({ 
        _id: 'target123',
        organizationId: 'org123',
        fullName: 'Old Name'
      });
      
      const updatedProfile = { ...targetProfile, fullName: 'New Name' };
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(targetProfile)
      });
      Profile.findByIdAndUpdate = jest.fn().mockResolvedValue(updatedProfile);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
        authorizeResource: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .put('/api/profile/target123')
        .send({ fullName: 'New Name' });

      expect(response.status).toBe(200);
      expect(Profile.findByIdAndUpdate).toHaveBeenCalledWith(
        'target123',
        { fullName: 'New Name' },
        { new: true, runValidators: true }
      );
      expect(logEvent).toHaveBeenCalledWith(
        adminProfile.supabaseUid,
        'profile_updated',
        'profile',
        'target123',
        expect.any(Object),
        expect.any(Object)
      );
    });

    it('should return 404 for missing profile', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(null)
      });

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
        authorizeResource: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .put('/api/profile/nonexistent')
        .send({ fullName: 'New Name' });

      expect(response.status).toBe(404);
      expect(response.body.error).toContain('Profile not found');
    });
  });

  describe('DELETE /api/profile/:id', () => {
    beforeEach(() => {
      Profile.findById = jest.fn();
      Profile.findByIdAndUpdate = jest.fn();
    });

    it('should soft-delete profile successfully', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const targetProfile = mockProfile({ 
        _id: 'target123',
        organizationId: 'org123',
        isActive: true
      });
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(targetProfile)
      });
      Profile.findByIdAndUpdate = jest.fn().mockResolvedValue({ ...targetProfile, isActive: false });

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
        authorizeResource: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .delete('/api/profile/target123');

      expect(response.status).toBe(200);
      expect(Profile.findByIdAndUpdate).toHaveBeenCalledWith(
        'target123',
        { isActive: false },
        { new: true }
      );
      expect(logEvent).toHaveBeenCalledWith(
        adminProfile.supabaseUid,
        'profile_deactivated',
        'profile',
        'target123',
        expect.any(Object),
        expect.any(Object)
      );
    });

    it('should return 404 for missing profile', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      Profile.findById = jest.fn().mockReturnValue({
        populate: jest.fn().mockResolvedValue(null)
      });

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
        authorizeResource: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .delete('/api/profile/nonexistent');

      expect(response.status).toBe(404);
      expect(response.body.error).toContain('Profile not found');
    });
  });
});
