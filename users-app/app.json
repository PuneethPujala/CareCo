{
  "expo": {
    "name": "CareCo",
    "slug": "careco-users",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/careco_features.png",
    "splash": {
      "image": "./assets/careco_features.png",
      "backgroundColor": "#0A2463",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.careco.users",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/careco_features.png",
        "backgroundColor": "#0A2463"
      },
      "package": "com.careco.users",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}