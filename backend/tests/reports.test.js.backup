process.env.NODE_ENV = 'test';
const request = require('supertest');
const app = require('../src/server');

// Mock Mongoose models
jest.mock('../src/models/Profile');
jest.mock('../src/models/Organization');
jest.mock('../src/models/AuditLog');

// Mock services
jest.mock('../src/services/auditService');

const Profile = require('../src/models/Profile');
const Organization = require('../src/models/Organization');
const AuditLog = require('../src/models/AuditLog');
const { getUserActivitySummary, getSecurityIncidents } = require('../src/services/auditService');

const { mockProfile, mockOrganization, mockAuditLog } = require('./helpers/mockModels');
const { fakeAuthenticate } = require('./helpers/mockAuth');

describe('Reports Routes', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  describe('GET /api/reports/user-activity', () => {
    beforeEach(() => {
      Profile.findOne = jest.fn();
      getUserActivitySummary = jest.fn();
    });

    it('should return activity for super_admin with userId param', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      const targetUser = mockProfile({ 
        supabaseUid: 'target-user-123',
        organizationId: 'org123'
      });
      
      const activitySummary = {
        totalLogins: 15,
        totalActions: 45,
        lastLogin: new Date('2024-01-15T10:30:00Z'),
        activityBreakdown: {
          login: 15,
          patient_view: 20,
          profile_update: 10,
        }
      };
      
      Profile.findOne = jest.fn().mockResolvedValue(targetUser);
      getUserActivitySummary = jest.fn().mockResolvedValue(activitySummary);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/user-activity')
        .query({ userId: 'target-user-123', days: 30 });

      expect(response.status).toBe(200);
      expect(response.body.userId).toBe('target-user-123');
      expect(response.body.activitySummary).toEqual(activitySummary);
      expect(getUserActivitySummary).toHaveBeenCalledWith('target-user-123', 30);
    });

    it('should return 400 for super_admin without userId', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/user-activity');

      expect(response.status).toBe(400);
      expect(response.body.error).toContain('userId is required for super admin');
    });

    it('should return activity for org_admin defaulting to self', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123',
        supabaseUid: 'admin-123'
      });
      
      const activitySummary = {
        totalLogins: 8,
        totalActions: 22,
        lastLogin: new Date('2024-01-15T10:30:00Z'),
      };
      
      getUserActivitySummary = jest.fn().mockResolvedValue(activitySummary);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/user-activity')
        .query({ days: 30 });

      expect(response.status).toBe(200);
      expect(response.body.userId).toBe('admin-123');
      expect(getUserActivitySummary).toHaveBeenCalledWith('admin-123', 30);
    });

    it('should return 403 for org_admin accessing different org user', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const targetUser = mockProfile({ 
        supabaseUid: 'target-user-123',
        organizationId: 'different-org' // Different org
      });
      
      Profile.findOne = jest.fn().mockResolvedValue(targetUser);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/user-activity')
        .query({ userId: 'target-user-123' });

      expect(response.status).toBe(403);
      expect(response.body.error).toContain('Access denied to user outside your organization');
    });

    it('should return activity for caller limited to self', async () => {
      const callerProfile = mockProfile({ 
        role: 'caller',
        organizationId: 'org123',
        supabaseUid: 'caller-123'
      });
      
      const activitySummary = {
        totalLogins: 5,
        totalActions: 12,
      };
      
      getUserActivitySummary = jest.fn().mockResolvedValue(activitySummary);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(callerProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/user-activity')
        .query({ userId: 'caller-123' }); // Same as self

      expect(response.status).toBe(200);
      expect(response.body.userId).toBe('caller-123');
    });

    it('should return 403 for caller accessing other user', async () => {
      const callerProfile = mockProfile({ 
        role: 'caller',
        organizationId: 'org123',
        supabaseUid: 'caller-123'
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(callerProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/user-activity')
        .query({ userId: 'other-user-123' }); // Different user

      expect(response.status).toBe(403);
      expect(response.body.error).toContain('Access denied to other users\' activity');
    });
  });

  describe('GET /api/reports/organization-stats', () => {
    beforeEach(() => {
      Organization.findById = jest.fn();
      Profile.aggregate = jest.fn();
    });

    it('should return stats for super_admin with organizationId', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      const organization = mockOrganization({ 
        _id: 'org123',
        name: 'Test Organization'
      });
      
      const userStats = [
        { _id: 'super_admin', count: 1 },
        { _id: 'org_admin', count: 2 },
        { _id: 'care_manager', count: 5 },
        { _id: 'caller', count: 10 },
      ];
      
      const recentActivity = [mockAuditLog({ action: 'login' })];
      
      Organization.findById = jest.fn().mockResolvedValue(organization);
      Profile.aggregate = jest.fn().mockResolvedValue(userStats);
      AuditLog.aggregate = jest.fn().mockResolvedValue(recentActivity);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/organization-stats')
        .query({ organizationId: 'org123' });

      expect(response.status).toBe(200);
      expect(response.body.organization._id).toBe('org123');
      expect(response.body.userStats).toEqual(userStats);
      expect(Profile.aggregate).toHaveBeenCalledWith([
        {
          $match: { organizationId: expect.any(Object) }
        },
        {
          $group: { _id: '$role', count: { $sum: 1 } }
        }
      ]);
    });

    it('should return 400 for super_admin without organizationId', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/organization-stats');

      expect(response.status).toBe(400);
      expect(response.body.error).toContain('organizationId is required for super admin');
    });

    it('should return stats for org_admin defaulting to own org', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const organization = mockOrganization({ 
        _id: 'org123',
        name: 'Test Organization'
      });
      
      const userStats = [
        { _id: 'care_manager', count: 3 },
        { _id: 'caller', count: 8 },
      ];
      
      Organization.findById = jest.fn().mockResolvedValue(organization);
      Profile.aggregate = jest.fn().mockResolvedValue(userStats);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/organization-stats');

      expect(response.status).toBe(200);
      expect(response.body.organization._id).toBe('org123');
      expect(Profile.aggregate).toHaveBeenCalled();
    });

    it('should return 403 for org_admin accessing different org', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/organization-stats')
        .query({ organizationId: 'different-org' });

      expect(response.status).toBe(403);
      expect(response.body.error).toContain('Access denied to other organizations');
    });

    it('should return 404 for missing organization', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      Organization.findById = jest.fn().mockResolvedValue(null);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/organization-stats')
        .query({ organizationId: 'nonexistent' });

      expect(response.status).toBe(404);
      expect(response.body.error).toContain('Organization not found');
    });
  });

  describe('GET /api/reports/security-incidents', () => {
    beforeEach(() => {
      getSecurityIncidents = jest.fn();
    });

    it('should return security incidents for super_admin', async () => {
      const superAdminProfile = mockProfile({ 
        role: 'super_admin',
        organizationId: 'super-org'
      });
      
      const incidents = [
        mockAuditLog({ action: 'login_failed', severity: 'medium' }),
        mockAuditLog({ action: 'unauthorized_access', severity: 'high' }),
      ];
      
      getSecurityIncidents = jest.fn().mockResolvedValue(incidents);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(superAdminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/security-incidents');

      expect(response.status).toBe(200);
      expect(response.body.incidents).toHaveLength(2);
      expect(getSecurityIncidents).toHaveBeenCalled();
    });

    it('should return security incidents for org_admin', async () => {
      const adminProfile = mockProfile({ 
        role: 'org_admin',
        organizationId: 'org123'
      });
      
      const incidents = [mockAuditLog({ action: 'login_failed' })];
      
      getSecurityIncidents = jest.fn().mockResolvedValue(incidents);

      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(adminProfile),
        requireRole: () => (req, res, next) => next(),
      }));
      
      // Mock authorize middleware
      jest.doMock('../src/middleware/authorize', () => ({
        authorize: () => (req, res, next) => next(),
      }));

      const response = await request(app)
        .get('/api/reports/security-incidents');

      expect(response.status).toBe(200);
      expect(response.body.incidents).toHaveLength(1);
      expect(getSecurityIncidents).toHaveBeenCalledWith(
        adminProfile.organizationId,
        expect.any(Object)
      );
    });

    it('should return 403 for caller accessing security incidents', async () => {
      const callerProfile = mockProfile({ 
        role: 'caller',
        organizationId: 'org123'
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(callerProfile),
        requireRole: () => (req, res, next) => {
          const error = new Error('Access denied');
          error.status = 403;
          throw error;
        },
      }));

      const response = await request(app)
        .get('/api/reports/security-incidents');

      expect(response.status).toBe(403);
    });

    it('should return 403 for patient accessing security incidents', async () => {
      const patientProfile = mockProfile({ 
        role: 'patient',
        organizationId: 'org123'
      });
      
      // Mock authenticate middleware
      jest.doMock('../src/middleware/authenticate', () => ({
        authenticate: fakeAuthenticate(patientProfile),
        requireRole: () => (req, res, next) => {
          const error = new Error('Access denied');
          error.status = 403;
          throw error;
        },
      }));

      const response = await request(app)
        .get('/api/reports/security-incidents');

      expect(response.status).toBe(403);
    });
  });
});
